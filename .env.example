WHATSAPP_PROVIDER=textmebot
WHATSAPP_CRON_SECRET=replace_with_random_secret
TEXTMEBOT_API_KEY=replace_with_textmebot_apikey
TEXTMEBOT_REMINDER_API_KEY=
TEXTMEBOT_BOOKING_API_KEY=

# Optional Twilio fallback
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=replace_with_new_token
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
TWILIO_REMINDER_WHATSAPP_FROM=
TWILIO_BOOKING_WHATSAPP_FROM=
TWILIO_CONTENT_SID=HXxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_BOOKING_ADMIN_CONTENT_SID=
TWILIO_BOOKING_PROFESSIONAL_CONTENT_SID=
TWILIO_BOOKING_CUSTOMER_CONTENT_SID=

# TextMeBot uses the same API key for reminders and bookings unless you override it above.
# Official send format:
# https://api.textmebot.com/send.php?recipient=573001234567&apikey=YOUR_API_KEY&text=Hola

# Optional if you also want Telegram reminders via env
# TELEGRAM_BOT_TOKEN=replace_with_bot_token
# TELEGRAM_BOT_USERNAME=your_bot_username
# TELEGRAM_CRON_SECRET=replace_with_random_secret
